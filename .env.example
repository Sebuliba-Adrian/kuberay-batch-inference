# ─── FastAPI proxy ───────────────────────────────────────────────────
# Static API key required on the X-API-Key header for every request.
# Generate a new one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=demo-api-key-change-me-in-production

# Log level: DEBUG|INFO|WARNING|ERROR
LOG_LEVEL=INFO

# ─── Ray cluster ─────────────────────────────────────────────────────
# Address of the Ray dashboard + Jobs API inside the cluster.
# For local dev via port-forward: http://localhost:8265
# Inside the kind cluster (from the API pod): http://qwen-raycluster-head-svc.ray.svc.cluster.local:8265
RAY_ADDRESS=http://localhost:8265

# Model identifier passed through to the inference job
MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct

# Upper bound on prompts per batch request
MAX_BATCH_SIZE=1000

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://batches:batches@localhost:5432/batches

# ─── Shared results storage ──────────────────────────────────────────
# Mounted into both the API pod and the Ray workers
RESULTS_DIR=/data/batches
